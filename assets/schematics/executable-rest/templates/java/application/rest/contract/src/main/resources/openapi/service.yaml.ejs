openapi: 3.1.0
info:
  title: <%= projectName %>
  version: 0.0.1
  description: |
    Walking-skeleton REST surface generated by @rgoussu.dev/keel.
    Extend this contract alongside your application/rest/contract DTOs.

paths:
  /ping:
    get:
      summary: Liveness probe — dispatches PingQuery through the mediator.
      operationId: ping
      responses:
        '200':
          description: OK
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PingResponse'
        default:
          description: Error — RFC 9457 problem details.
          content:
            application/problem+json:
              schema:
                $ref: '#/components/schemas/Problem'

components:
  schemas:
    PingResponse:
      type: object
      required: [message, at]
      additionalProperties: false
      properties:
        message:
          type: string
          description: Human-readable status token. Defaults to "pong".
        at:
          type: string
          format: date-time
          description: Server time when the response was produced.
    Problem:
      type: object
      required: [type, title, status]
      additionalProperties: true
      properties:
        type:
          type: string
          format: uri
          default: 'about:blank'
        title:
          type: string
        detail:
          type: string
        status:
          type: integer
          format: int32
