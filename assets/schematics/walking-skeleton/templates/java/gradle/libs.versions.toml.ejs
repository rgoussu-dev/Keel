[versions]
# Pinned to the latest stable at walking-skeleton time. Run `keel doctor`
# or the `always latest` review quarterly to bump.
junit = "5.11.4"
assertj = "3.27.0"
archunit = "1.3.0"
pitest = "1.17.0"
jspecify = "1.0.0"
errorprone = "2.36.0"
nullaway = "0.12.3"

[libraries]
junit-bom     = { module = "org.junit:junit-bom",                version.ref = "junit" }
junit-jupiter = { module = "org.junit.jupiter:junit-jupiter" }
assertj-core  = { module = "org.assertj:assertj-core",           version.ref = "assertj" }
archunit      = { module = "com.tngtech.archunit:archunit-junit5", version.ref = "archunit" }
jspecify      = { module = "org.jspecify:jspecify",              version.ref = "jspecify" }
errorprone-core = { module = "com.google.errorprone:error_prone_core", version.ref = "errorprone" }
nullaway      = { module = "com.uber.nullaway:nullaway",         version.ref = "nullaway" }

[plugins]
spotless = { id = "com.diffplug.spotless", version = "7.0.1" }
pitest   = { id = "info.solidsoft.pitest", version = "1.15.0" }
