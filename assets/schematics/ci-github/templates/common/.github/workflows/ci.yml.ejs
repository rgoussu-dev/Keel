name: ci

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: read
  id-token: write

jobs:
  build-test-package:
    runs-on: ubuntu-latest
    outputs:
      image_tag: ${{ steps.image.outputs.tag }}
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '21'
          cache: gradle

      - name: Gradle check + build
        run: ./gradlew check build --no-daemon --stacktrace

      - id: image
        name: Compute image tag
        run: echo "tag=sha-${GITHUB_SHA::12}" >> "$GITHUB_OUTPUT"

      - name: Authenticate to Google Cloud
        if: github.ref == 'refs/heads/main'
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WIF_PROVIDER }}
          service_account: ${{ secrets.GCP_DEPLOYER_SA_EMAIL }}

      - name: Configure Docker for Artifact Registry
        if: github.ref == 'refs/heads/main'
        run: gcloud auth configure-docker ${{ secrets.GCP_REGION }}-docker.pkg.dev --quiet

      - name: Build + push native image
        if: github.ref == 'refs/heads/main'
        env:
          IMAGE: ${{ secrets.GCP_ARTIFACT_REGISTRY_URL }}/rest:${{ steps.image.outputs.tag }}
        run: |
          docker build -f iac/cloudrun/Dockerfile -t "$IMAGE" .
          docker push "$IMAGE"

  deploy:
    if: github.ref == 'refs/heads/main'
    needs: build-test-package
    runs-on: ubuntu-latest
    permissions:
      contents: read
      id-token: write
    steps:
      - uses: actions/checkout@v4

      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WIF_PROVIDER }}
          service_account: ${{ secrets.GCP_DEPLOYER_SA_EMAIL }}

      - name: Setup OpenTofu
        uses: opentofu/setup-opentofu@v1
        with:
          tofu_version: 1.8.6

      - name: Tofu init
        working-directory: iac/cloudrun
        run: tofu init -backend-config=bucket=${{ secrets.GCP_PROJECT_ID }}-tofu-state

      - name: Tofu apply (deploys the new revision)
        working-directory: iac/cloudrun
        env:
          IMAGE: ${{ secrets.GCP_ARTIFACT_REGISTRY_URL }}/rest:${{ needs.build-test-package.outputs.image_tag }}
        run: |
          tofu apply -auto-approve \
            -var project_id=${{ secrets.GCP_PROJECT_ID }} \
            -var region=${{ secrets.GCP_REGION }} \
            -var service_name=<%= serviceName %> \
            -var image="$IMAGE"

      - name: Smoke test /ping
        working-directory: iac/cloudrun
        run: |
          url=$(tofu output -raw service_url)
          token=$(gcloud auth print-identity-token --audiences="$url")
          echo "Smoke-testing $url/ping"
          for i in {1..5}; do
            if curl -fsS -H "Authorization: Bearer $token" "$url/ping" | grep -q '"message":"pong"'; then
              echo "ok"; exit 0
            fi
            sleep 5
          done
          echo "smoke test failed" >&2
          exit 1
