package <%= basePackage %>.cli;

import picocli.CommandLine.Command;
import picocli.CommandLine.Option;

/**
 * Sample subcommand. The walking skeleton ships with one runnable
 * command end-to-end (the test in `HelloCommandTest` proves it walks)
 * — replace it with real domain commands as the project grows.
 */
@Command(name = "hello", description = "Print a friendly greeting.")
public final class HelloCommand implements Runnable {

    @Option(names = {"--name"}, defaultValue = "world", description = "Recipient of the greeting.")
    String name;

    @Override
    public void run() {
        System.out.println("Hello, " + name + "!");
    }
}
