package <%= basePackage %>.cli;

import io.quarkus.picocli.runtime.annotations.TopCommand;
import picocli.CommandLine.Command;

/**
 * Top-level entry point for the {@value #NAME} CLI. Subcommands are
 * declared on the {@link Command#subcommands} attribute; add new ones
 * by writing a Runnable annotated with {@link Command} and listing
 * its class here.
 */
@TopCommand
@Command(
    name = Main.NAME,
    mixinStandardHelpOptions = true,
    description = "Walking skeleton CLI scaffolded by keel.",
    subcommands = {HelloCommand.class}
)
public final class Main {
    public static final String NAME = "<%= projectName %>";

    private Main() {}
}
