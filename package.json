{
  "name": "@rgoussu.dev/keel",
  "version": "0.1.0-alpha.1",
  "description": "Universal Claude Code workflow kit: hexagonal architecture, trunk-based development, XP, walking skeleton, schematics.",
  "type": "module",
  "bin": {
    "keel": "bin/keel.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "dist",
    "assets",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json -w",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "claude-code",
    "hexagonal",
    "ports-and-adapters",
    "trunk-based",
    "xp",
    "walking-skeleton",
    "scaffolding",
    "schematics",
    "cqrs",
    "mediator"
  ],
  "author": "rgoussu.dev",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ejs": "^3.1.10",
    "fs-extra": "^11.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.0"
  }
}
